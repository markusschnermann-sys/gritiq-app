# ──────────────────────────────────────────────────────────────
# GritIQ — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Path to SQLite database file.
# In Docker / Render: set to /data/data.db (mounted persistent volume)
# Locally: leave as default (project root)
DATABASE_PATH=./data.db

# ── Auth — JWT ────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change_me_generate_with_openssl_rand_base64_48
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_base64_48_different

# ── Stripe ────────────────────────────────────────────────────
# Live keys: https://dashboard.stripe.com/apikeys
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID_MONTHLY=price_...   # 9,99 € / month
STRIPE_PRICE_ID_ANNUAL=price_...    # 79,99 € / year
STRIPE_WEBHOOK_SECRET=whsec_...     # from: stripe listen --print-secret

# ── OpenAI — ATLAS AI Coach ───────────────────────────────────
# Required for the AI coach feature. Get a key at https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ── App URL ───────────────────────────────────────────────────
# Full public URL of your deployment (no trailing slash).
# Used for referral links and Stripe success/cancel redirects.
# Example: https://gritiq.yourdomain.com
APP_URL=http://localhost:5000
